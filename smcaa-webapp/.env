# Azure AD (Entra ID) App Registration — SPA authentication
# NOTE: In Create React App these are embedded into the build at BUILD time and
# must be prefixed with REACT_APP_. The client ID and tenant ID are NOT secrets.

REACT_APP_AZURE_CLIENT_ID=1ba57d22-6a43-4076-939f-6a88406578ad
REACT_APP_AZURE_TENANT_ID=e38419c3-ab61-40d7-b9ff-764e713ae18e

# Optional: override the redirect URI. Leave unset to use the current site origin
# (e.g. http://localhost:3000 in dev, or your hosting domain in production).
# REACT_APP_REDIRECT_URI=https://your-hosting-domain.example.com

# Web3Forms — public access key for the contact form. Safe to embed client-side:
# it only permits submitting to your form. Get yours at https://web3forms.com.
REACT_APP_WEB3FORMS_ACCESS_KEY=6e5948d6-08c9-4617-bc30-f5414ab004a0
